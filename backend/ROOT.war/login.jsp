<%@ page import="java.util.Hashtable, javax.naming.Context, javax.naming.directory.*, javax.naming.NamingEnumeration" %><%@ page contentType="application/json;charset=UTF-8" %><%
String user=request.getParameter("username"), pass=request.getParameter("password");
Hashtable<String, String> env = new Hashtable<>(); env.put(Context.INITIAL_CONTEXT_FACTORY, "com.sun.jndi.ldap.LdapCtxFactory"); env.put(Context.SECURITY_AUTHENTICATION, "simple"); env.put(Context.SECURITY_PRINCIPAL, user+"@itu.local"); env.put(Context.SECURITY_CREDENTIALS, pass); env.put(Context.PROVIDER_URL, "ldap://192.168.10.10:389");
try { DirContext ctx = new InitialDirContext(env); SearchControls sc = new SearchControls(); sc.setSearchScope(SearchControls.SUBTREE_SCOPE); sc.setReturningAttributes(new String[]{"memberOf"}); NamingEnumeration<SearchResult> rs = ctx.search("DC=itu,DC=local", "(&(objectClass=user)(sAMAccountName="+user+"))", sc); String rol = "alumno"; if(rs.hasMoreElements()){ Attribute mo = rs.nextElement().getAttributes().get("memberOf"); if(mo!=null) for(int i=0; i<mo.size(); i++) if(mo.get(i).toString().toLowerCase().contains("cn=admins")) rol="admin"; } ctx.close(); out.print("{\"success\":true,\"username\":\""+user+"\",\"role\":\""+rol+"\"}"); } catch (Exception e) { out.print("{\"success\":false}"); }
%>
